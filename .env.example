# ============================================================
# BlackRoad OS, Inc. — Environment Configuration
# Copyright © 2026 BlackRoad OS, Inc. All Rights Reserved.
# ============================================================
# Copy this file to .env.local and fill in your credentials.
# NEVER commit .env.local to version control.
# All API traffic must route through the BlackRoad Converter API.
# ============================================================

# ------------------------------------------------------------
# BlackRoad Converter API
# Obtain from: blackroad.systems@gmail.com
# Required to proxy all vendor AI/payment API calls.
# ------------------------------------------------------------
BLACKROAD_CONVERTER_API_KEY=
BLACKROAD_CONVERTER_API_URL=https://api.blackroad.io/v1/converter

# ------------------------------------------------------------
# OAuth — BlackRoad Contributor Authentication
# Issued alongside your Converter API key.
# ------------------------------------------------------------
BLACKROAD_OAUTH_CLIENT_ID=
BLACKROAD_OAUTH_CLIENT_SECRET=
BLACKROAD_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# ------------------------------------------------------------
# Stripe — RoadCoin Payments
# https://dashboard.stripe.com/apikeys
# All Stripe calls must route via the Converter API.
# ------------------------------------------------------------
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ------------------------------------------------------------
# Cloudflare
# Used for CDN, DNS, and Tunnel configuration.
# https://dash.cloudflare.com/profile/api-tokens
# ------------------------------------------------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# ------------------------------------------------------------
# Tailscale
# Used for secure mesh networking within BlackRoad infra.
# https://login.tailscale.com/admin/settings/keys
# ------------------------------------------------------------
TAILSCALE_AUTHKEY=

# ------------------------------------------------------------
# Site
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://roadcoin.io
